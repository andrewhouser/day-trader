# Ollama LLM server
OLLAMA_BASE_URL=http://localhost:11434

# Model assignments (each agent uses the model best suited to its task)
TRADER_MODEL_NAME=deepseek-r1:14b       # Core trading agent — complex reasoning, trade decisions
RESEARCH_MODEL=qwen3.5:latest           # Research, summarizer, performance, rebalancer — analysis/long context
REPORT_MODEL=qwen2.5:7b                 # Morning report — formatting/summarization
SENTIMENT_MODEL=llama3.1:8b             # Sentiment agent — classification
EVENTS_MODEL=qwen2.5:7b                 # Events calendar — structured generation (fast)
EXPANSION_MODEL=qwen3.5:latest          # Expansion analysis — portfolio analysis
COMPACTION_MODEL=phi3:3.8b              # Compaction — lightweight summarization (runs frequently)

# Timeout settings (seconds)
OLLAMA_TIMEOUT=300                       # Default timeout for all Ollama requests
EVENTS_TIMEOUT=600                       # Extended timeout for events calendar agent
RESEARCH_TIMEOUT=600                     # Extended timeout for research agent (two LLM calls per cycle)
OVERSEAS_TIMEOUT=600                     # Timeout for overseas market monitor agents

# Overseas market monitor model (leave empty to use RESEARCH_MODEL)
# OVERSEAS_MODEL=qwen2.5:7b

# Overseas market monitor schedules (ET — adjust for DST manually if needed)
# Nikkei / Tokyo: morning session ~7:30 PM–10:30 PM ET Sun–Thu
# NIKKEI_OPEN_CRON=*/10 19-22 * * 0-4
# Nikkei reopen / Asia continuation: ~11 PM–2:30 AM ET
# NIKKEI_REOPEN_CRON=*/15 23 * * 0-4
# NIKKEI_REOPEN_LATE_CRON=*/15 0-2 * * 1-5
# FTSE / London: ~2:30 AM–5:30 AM ET Mon–Fri
# FTSE_OPEN_CRON=*/10 2-5 * * 1-5
# Europe Handoff Summary: 5:30 AM ET Mon–Fri (after FTSE monitor, before Morning Report)
# EUROPE_HANDOFF_CRON=30 5 * * 1-5

# Multi-source research engine API keys (all optional — adapters degrade gracefully)
FRED_API_KEY=
FINNHUB_API_KEY=
ALPHA_VANTAGE_KEY=
SEC_EDGAR_CONTACT=research-agent@example.com
